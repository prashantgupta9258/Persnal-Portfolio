{
  "collections": {
    "contacts": {
      "rules": [
        {
          "allow": "read",
          "condition": "false"
        },
        {
          "allow": "create",
          "condition": "true"
        }
      ],
      "schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "createdAt": {
            "type": "timestamp"
          }
        },
        "required": ["name", "email", "message", "createdAt"]
      }
    }
  }
}
